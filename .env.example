# RotaLog — variáveis de ambiente de exemplo
# Copie este arquivo para .env e ajuste conforme o ambiente.

# URL base da API REST.
# Em desenvolvimento local, use /api/v1 para que o proxy do Vite encaminhe as
# chamadas para https://api.rotalog.madebyhermes.com sem problemas de CORS.
# Em produção, use a URL completa:
#   VITE_API_URL=https://api.rotalog.madebyhermes.com/api/v1
VITE_API_URL=/api/v1

# URL do servidor WebSocket (usado pelo serviço de tempo real).
VITE_WS_URL=wss://api.rotalog.madebyhermes.com/ws

# Define se a integração real com o backend está ativa.
# Defina como false apenas para testes puramente locais sem backend.
VITE_USE_API=true

# Habilita modo demo somente em desenvolvimento (login/cadastro simulados).
# Nunca ative em produção.
# VITE_ENABLE_DEMO_AUTH=false
